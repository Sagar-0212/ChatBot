# RIT College AI Chatbot Environment Configuration Template
# Rename this file to .env and configure the values for development/production.

# Flask secret key for session signing
SECRET_KEY=rit-college-chatbot-super-secret-key-12345

# Debug mode (True/False)
DEBUG=True

# SQLite Database connection string
# For standard Python sqlite3, we support sqlite:///path/to/database.db format
DATABASE_URL=sqlite:///database/college_chatbot.db

# JWT settings
JWT_SECRET_KEY=rit-college-jwt-token-signing-secret-67890
JWT_EXPIRY_HOURS=24

# Machine Learning model and vectorizer paths
MODEL_PATH=trained_models/chatbot_model.pkl
VECTORIZER_PATH=trained_models/vectorizer.pkl

# CORS configurations
CORS_ORIGINS=*
